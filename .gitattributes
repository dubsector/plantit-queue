# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly text
*.java    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.xml     text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.properties text eol=lf

# Binary — no line-ending conversion
*.jar     binary
*.png     binary
*.jpg     binary
